{
  "expo": {
    "name": "Silk Value",
    "slug": "silk-value",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "silkvalue",
    "splash": {
      "backgroundColor": "#ffffff"
    },
    "platforms": ["android"],
    "jsEngine": "hermes",
    "android": {
      "package": "com.silkvalue.app"
    },
    "plugins": [
      "@morrowdigital/watermelondb-expo-plugin",
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.8.10",
            "packagingOptions": {
              "pickFirst": ["**/libc++_shared.so"]
            }
          }
        }
      ]
    ]
  }
}
